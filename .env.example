# ============================================
# API Keys - 支持多个密钥实现负载均衡
# ============================================

# Claude AI (Anthropic) - 支持 10 个密钥轮换
ANTHROPIC_API_KEY_1=sk-ant-your_key_here
ANTHROPIC_API_KEY_2=sk-ant-your_key_here
ANTHROPIC_API_KEY_3=sk-ant-your_key_here
# ... 可添加更多

# GMGN API - 支持 5 个密钥
GMGN_API_KEY_1=your_gmgn_api_key_here
GMGN_API_KEY_2=your_gmgn_api_key_here
# ... 可添加更多

# Etherscan API
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Alchemy API
ALCHEMY_API_KEY=your_alchemy_api_key_here

# ============================================
# 服务器配置
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# 缓存 (Redis) - 生产环境推荐启用
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password

# ============================================
# 数据库 (PostgreSQL) - 生产环境使用
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/hold_portal

# ============================================
# JWT 认证
# ============================================
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRES_IN=7d

# ============================================
# 邮件服务 (SMTP) - 用于价格提醒
# ============================================
# Gmail 示例（需要应用专用密码）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password

# 或使用其他 SMTP 服务
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=587
# SMTP_USER=your_email@qq.com
# SMTP_PASS=your_password

# ============================================
# 限流配置
# ============================================
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=10

# ============================================
# 平台代币 (可选)
# ============================================
PLATFORM_TOKEN_ADDRESS=your_platform_token_address_here
PLATFORM_TOKEN_CHAIN=bsc
